# RSS（多个用逗号或换行）
RSS_URLS=

# Worker 定时（控制 worker 整体：AI/flush/RSS；不填=全天每 10 分钟）
# 例："*/10 6-22 * * *"
WORKER_CRON=

# RSS 定时（只管抓 RSS，不影响 AI/flush）
# 例："*/15 6-22 * * *"
RSS_CRON=

# AI（只用 litellm）
AI_API_KEY=
# 例：openai/gpt-5.2, gemini/gemini-1.5-pro
AI_MODEL=openai/gpt-5.2
# 可选：OpenAI 兼容接口 base_url（比如你的网关）
AI_BASE_URL=
AI_API_MODE=responses
AI_STREAM=1
AI_TIMEOUT_SEC=1000
AI_TEMPERATURE=0.1
AI_REASONING_EFFORT=xhigh
AI_RPM=12
AI_RETRIES=11
AI_MAX_INFLIGHT=12
# weibo_assertions_v1：单条微博分析（旧版）
# topic-prompt-v3：合并同一串对话（message_tree）再分析（新版）
AI_PROMPT_VERSION=topic-prompt-v3
# 可选：写 trace 文件。例：/data/trace.txt
AI_TRACE_OUT=

# Turso（云端归档库）
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# 单进程最大 Turso 连接数（直连模式建议设置小一点；容器开多份时总连接数=容器数×这个值）
TURSO_MAX_CONNECTIONS=4

# Redis（可选：Turso 挂了时的备用队列）
REDIS_URL=
REDIS_QUEUE_KEY=alphavault:rss_spool

# spool（本地临时文件，默认 /tmp/alphavault-spool）
SPOOL_DIR=
