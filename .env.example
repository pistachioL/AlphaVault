# RSS（多个用逗号或换行）
# 只跑微博：填 WEIBO_ 这一组
WEIBO_RSS_URLS=
WEIBO_RSS_URL=
WEIBO_AUTHOR=
WEIBO_USER_ID=
# 只跑雪球：填 XUEQIU_ 这一组
XUEQIU_RSS_URLS=
XUEQIU_RSS_URL=
XUEQIU_AUTHOR=
XUEQIU_USER_ID=

# Worker 定时（控制 worker 整体：AI/flush/RSS）
# 按启动方式选一组：
# 1. 容器 / docker compose：填 WORKER_CRON
#    entrypoint.sh 会把它转成下面的 ACTIVE_HOURS 和 INTERVAL_SECONDS
#    例："*/10 6-22 * * *"
# 2. 直接跑 Python：
#    `uv run python weibo_rss_worker.py --log-level info`
#    这时不看 WORKER_CRON，直接看下面的 ACTIVE_HOURS / INTERVAL_SECONDS
WORKER_CRON=
# 时段格式：6-22；不填=全天
WORKER_ACTIVE_HOURS=
# 间隔秒数；默认 600
WORKER_INTERVAL_SECONDS=
# 个股热度缓存刷新间隔秒数；默认 60，最小 15
WORKER_STOCK_HOT_CACHE_INTERVAL_SECONDS=

# RSS 定时（只管抓 RSS，不影响 AI/flush）
# 按启动方式选一组：
# 1. 容器 / docker compose：填 RSS_CRON
#    entrypoint.sh 会把它转成下面的 ACTIVE_HOURS 和 INTERVAL_SECONDS
#    例："*/15 6-22 * * *"
# 2. 直接跑 Python worker：
#    不看 RSS_CRON，直接看下面的 ACTIVE_HOURS / INTERVAL_SECONDS
RSS_CRON=
# 时段格式：6-22；不填=全天
RSS_ACTIVE_HOURS=
# 间隔秒数；默认 600
RSS_INTERVAL_SECONDS=
# RSS 抓取网络参数
# 单次请求超时（秒），默认 60
RSS_TIMEOUT_SECONDS=60
# 失败后最多重试次数（不含首次），默认 5
RSS_RETRIES=5
# 每个 feed 抓完后，抓下一个 feed 前 sleep 秒数（默认 10；设为 0 可关闭）
RSS_FEED_SLEEP_SECONDS=10
# 手动触发 worker admin API 的鉴权 key（/api/rss/trigger 和 /api/admin/requeue-from-db）
WORKER_ADMIN_TRIGGER_KEY=

# AI（只用 litellm）
AI_API_KEY=
# 例：openai/gpt-5.2, gemini/gemini-1.5-pro
AI_MODEL=openai/gpt-5.2
# 可选：OpenAI 兼容接口 base_url（比如你的网关）
AI_BASE_URL=
AI_API_MODE=responses
AI_STREAM=1
AI_TIMEOUT_SEC=1000
AI_TEMPERATURE=0.1
AI_REASONING_EFFORT=xhigh
# 默认限流组；任务和 profile 没单独绑限流组时，都会共用这两个值
AI_RPM=12
AI_RETRIES=11
AI_MAX_INFLIGHT=12
# 可选：按任务切配置档。没配时默认走上面的 AI_*。
AI_TASK_POST_ANALYSIS_PROFILE=
AI_TASK_POST_CONTEXT_PROFILE=
AI_TASK_ALIAS_RESOLVE_PROFILE=
AI_TASK_RELATION_CANDIDATE_RANK_PROFILE=
AI_TASK_TOPIC_CLUSTER_SUGGEST_PROFILE=
AI_TASK_FOLLOW_KEYWORDS_SUGGEST_PROFILE=
# 可选：任务也可以直接绑限流组。没配时先看 profile 的 LIMIT_GROUP，再回退到默认限流组。
AI_TASK_POST_ANALYSIS_LIMIT_GROUP=
AI_TASK_POST_CONTEXT_LIMIT_GROUP=
AI_TASK_ALIAS_RESOLVE_LIMIT_GROUP=
AI_TASK_RELATION_CANDIDATE_RANK_LIMIT_GROUP=
AI_TASK_TOPIC_CLUSTER_SUGGEST_LIMIT_GROUP=
AI_TASK_FOLLOW_KEYWORDS_SUGGEST_LIMIT_GROUP=
# 可选：自定义配置档字段。没填的字段会回退到默认 AI_*。
AI_PROFILE_CONTEXT_API_KEY=
AI_PROFILE_CONTEXT_MODEL=
AI_PROFILE_CONTEXT_BASE_URL=
AI_PROFILE_CONTEXT_API_MODE=
AI_PROFILE_CONTEXT_TIMEOUT_SEC=
AI_PROFILE_CONTEXT_TEMPERATURE=
AI_PROFILE_CONTEXT_REASONING_EFFORT=
AI_PROFILE_CONTEXT_RETRIES=
# 可选：给 profile 绑一个默认限流组。例：context_lane
AI_PROFILE_CONTEXT_LIMIT_GROUP=
# 可选：自定义限流组字段。例：
# AI_LIMIT_GROUP_CONTEXT_LANE_RPM=12
# AI_LIMIT_GROUP_CONTEXT_LANE_MAX_INFLIGHT=50
# 队列任务拿走后，多久没完成就算卡住（秒），默认 3600
AI_QUEUE_ACK_TIMEOUT_SEC=3600
# weibo_assertions_v1：单条微博分析（旧版）
# topic-prompt-v3：合并同一串对话（message_tree）再分析（新版）
AI_PROMPT_VERSION=topic-prompt-v3
# 可选：写 trace 文件。例：/data/trace.txt
AI_TRACE_OUT=

# Embedding（给 semantic_docs 和语义查询单独用）
# 当前 semantic_docs 表按 2048 维建表，默认对应 `Qwen/Qwen3-Embedding-8B`
# 同名 AI profile 已配置站点信息时，这里可只填模型差异字段；`API_KEY`、`BASE_URL`、
# `TIMEOUT_SEC`、`RETRIES` 和限流组会自动回退到同名 `AI_PROFILE_*` / `AI_LIMIT_GROUP_*`
EMBEDDING_API_KEY=
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIMENSIONS=2048
EMBEDDING_BASE_URL=
EMBEDDING_TIMEOUT_SEC=60
EMBEDDING_RETRIES=5
EMBEDDING_BATCH_SIZE=32
# 默认限流组；任务和 profile 没单独绑限流组时，都会共用这两个值
EMBEDDING_RPM=120
EMBEDDING_MAX_INFLIGHT=8
# 可选：按任务切配置档。没配时默认走上面的 EMBEDDING_*。
EMBEDDING_TASK_SEMANTIC_DOC_SYNC_PROFILE=
EMBEDDING_TASK_SEMANTIC_QUERY_PROFILE=
# 可选：任务也可以直接绑限流组。没配时先看 profile 的 LIMIT_GROUP，再回退到默认限流组。
EMBEDDING_TASK_SEMANTIC_DOC_SYNC_LIMIT_GROUP=
EMBEDDING_TASK_SEMANTIC_QUERY_LIMIT_GROUP=
# 可选：自定义配置档字段。没填的字段会回退到默认 EMBEDDING_*。
EMBEDDING_PROFILE_FAST_API_KEY=
EMBEDDING_PROFILE_FAST_MODEL=
EMBEDDING_PROFILE_FAST_DIMENSIONS=
EMBEDDING_PROFILE_FAST_BASE_URL=
EMBEDDING_PROFILE_FAST_TIMEOUT_SEC=
EMBEDDING_PROFILE_FAST_RETRIES=
EMBEDDING_PROFILE_FAST_BATCH_SIZE=
# 可选：给 profile 绑一个默认限流组。例：fast_lane
EMBEDDING_PROFILE_FAST_LIMIT_GROUP=
# 可选：自定义限流组字段。例：
# EMBEDDING_LIMIT_GROUP_FAST_LANE_RPM=240
# EMBEDDING_LIMIT_GROUP_FAST_LANE_MAX_INFLIGHT=16

# Reranker（给语义召回后的重排单独用）
# 同名 AI profile 已配置站点信息时，这里可只填模型差异字段；`API_KEY`、`BASE_URL`、
# `TIMEOUT_SEC`、`RETRIES` 和限流组会自动回退到同名 `AI_PROFILE_*` / `AI_LIMIT_GROUP_*`
RERANKER_API_KEY=
RERANKER_MODEL=Qwen/Qwen3-Reranker-8B
RERANKER_BASE_URL=
RERANKER_TIMEOUT_SEC=60
RERANKER_RETRIES=3
RERANKER_TOP_N=20
# 默认限流组；任务和 profile 没单独绑限流组时，都会共用这两个值
RERANKER_RPM=60
RERANKER_MAX_INFLIGHT=4
# 可选：按任务切配置档。没配时默认走上面的 RERANKER_*。
RERANKER_TASK_SEMANTIC_QUERY_PROFILE=
RERANKER_TASK_SEMANTIC_QUERY_LIMIT_GROUP=
# 可选：自定义配置档字段。没填的字段会回退到默认 RERANKER_*。
RERANKER_PROFILE_FAST_API_KEY=
RERANKER_PROFILE_FAST_MODEL=
RERANKER_PROFILE_FAST_BASE_URL=
RERANKER_PROFILE_FAST_TIMEOUT_SEC=
RERANKER_PROFILE_FAST_RETRIES=
RERANKER_PROFILE_FAST_TOP_N=
# 可选：给 profile 绑一个默认限流组。例：fast_lane
RERANKER_PROFILE_FAST_LIMIT_GROUP=
# 可选：自定义限流组字段。例：
# RERANKER_LIMIT_GROUP_FAST_LANE_RPM=120
# RERANKER_LIMIT_GROUP_FAST_LANE_MAX_INFLIGHT=8

# Postgres（Supabase / 本地 PG）
# 所有 schema 共用一个 DSN：weibo / xueqiu / standard
# startup healthcheck 默认只查 standard；可选 weibo / xueqiu / standard
STARTUP_HEALTHCHECK_SCHEMA_TARGET=standard
POSTGRES_DSN=
# 单进程最大 Postgres 连接数
POSTGRES_POOL_MAX_SIZE=4

# Redis（可选：运行态队列和缓存）
# 没配就只走本地 spool + Postgres
REDIS_URL=
REDIS_QUEUE_KEY=alphavault:rss_spool
# Redis 去重 key 过期秒数（默认 7 天）
REDIS_DEDUP_TTL_SECONDS=604800
# AI 队列最大长度（超出会自动裁剪，避免 Redis 爆内存）
REDIS_AI_QUEUE_MAXLEN=20000

# spool（本地临时文件，默认 /tmp/alphavault-spool）
SPOOL_DIR=

# ntfy 告警（不填 `NTFY_TOPIC` 就关闭）
NTFY_URL=https://ntfy.sh
## 只填 topic 名，例如：rss-filter-ntfy-worker-error-xxxx
## 也兼容完整 URL，例如：https://ntfy.sh/rss-filter-ntfy-worker-error-xxxx
NTFY_TOPIC=
NTFY_TOKEN=
# 同类错误窗口期秒数：首条立刻发，窗口结束后再补一条汇总
NTFY_ALERT_DEDUP_WINDOW_SECONDS=900
# 单次发告警请求超时秒数
NTFY_ALERT_TIMEOUT_SECONDS=10

# Reflex（可选：homework/source 并发读取 worker 数，默认 2）
REFLEX_HOMEWORK_SOURCE_MAX_WORKERS=

# ============================================
# Zilliz Cloud 向量数据库配置（替代 Postgres pgvector）
# ============================================
# 用于存储 semantic_docs 的向量数据，释放 Supabase 免费额度空间
# 获取凭证：https://cloud.zilliz.com/ -> 创建免费集群 -> 复制 Cluster URI 和 API Key
# 详细说明：见 scripts/migrate_to_zilliz_readme.md

# 必填：Zilliz Cloud 集群 URI
ZILLIZ_CLOUD_URI=

# 必填：Zilliz Cloud API Token
ZILLIZ_CLOUD_TOKEN=

# 可选：迁移模式（默认 dual_write）
# - dual_write: 同时写入 Postgres 和 Zilliz（迁移过渡期，推荐）
# - zilliz_only: 只写入 Zilliz（完全迁移后，可删除 Postgres semantic_docs 表）
# - postgres_only: 只写入 Postgres（禁用 Zilliz，回滚兼容）
# 详细说明：见 scripts/zilliz_incremental_sync_guide.md
ZILLIZ_MIGRATION_MODE=dual_write
