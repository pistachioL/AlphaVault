# RSS（多个用逗号或换行）
RSS_URLS=

# 定时（推荐：简化 cron）："*/15 6-22 * * *"
RSS_CRON=

# AI（只用 litellm）
AI_API_KEY=
# 例：openai/gpt-5.2, gemini/gemini-1.5-pro
AI_MODEL=openai/gpt-5.2
# 可选：OpenAI 兼容接口 base_url（比如你的网关）
AI_BASE_URL=
AI_API_MODE=responses
AI_STREAM=1
AI_TIMEOUT_SEC=1000
AI_TEMPERATURE=0.1
AI_REASONING_EFFORT=xhigh
AI_RPM=12
AI_RETRIES=11
AI_MAX_INFLIGHT=30
AI_PROMPT_VERSION=weibo_assertions_v1
AI_TRACE_OUT=/data/trace.txt

# Turso（云端归档库）
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Redis（可选：Turso 挂了时的备用队列）
REDIS_URL=
REDIS_QUEUE_KEY=alphavault:rss_spool

# spool（本地临时文件，默认 /tmp/alphavault-spool）
SPOOL_DIR=
